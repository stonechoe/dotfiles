#!/bin/zsh
include_hidden=0

# Parse flags
while [[ "$1" == -* ]]; do
  case "$1" in
    --hidden) include_hidden=1; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# start directory (default: current directory)
start_dir="${1:-.}"

# search for .git directories
if [[ "$include_hidden" -eq 1 ]]; then
  find "$start_dir" -type d -name ".git"
else
  find "$start_dir" -mindepth 1 -name ".*" -not -name ".git" -prune -o -type d -name ".git" -print
fi | while read gitdir; do
    echo "${gitdir%/.git}"
done
