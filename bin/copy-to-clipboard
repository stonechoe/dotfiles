#!/usr/bin/env bash
# `copy to clipboard` using OSC 52

set -euo pipefail

case "${TERM_PROGRAM:-$TERM}" in
  WezTerm|ghostty|kitty|iTerm.app) ;;
  *) echo "warn: terminal may not support OSC 52" >&2 ;;
esac

data="$(cat)"
b64="$(printf '%s' "$data" | base64 | tr -d '\r\n')"
printf '\033]52;c;%s\a' "$b64"
